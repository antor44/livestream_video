{
  "manifest_version": 3,
  "name": "Audio Transcription",
  "version": "2.8.0",
  "description": "Fork of WhisperLive's Audio Transcription extension that captures audio from the active tab and sends it to a server for real-time transcription, translation, and TTS.",
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "tabCapture",
    "scripting",
    "tts"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://clients5.google.com/*"
  ],
  "icons": {
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon128.png"
  }
}
